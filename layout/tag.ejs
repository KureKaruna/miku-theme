<%- partial('partial/head') %>
<%- partial('partial/header') %>

<main id="main-content">
  <div class="tags-container">
    <h1 class="page-title kinetic-title"># <%= page.tag %></h1>
    <p class="search-empty">
      <span data-i18n="tags.moved"><%= __('tags.moved') %></span>
      <a href="<%= url_for('/search/?tag=' + encodeURIComponent(page.tag)) %>" data-i18n="tags.go_search"><%= __('tags.go_search') %></a>
    </p>
  </div>
</main>

<script>
  window.location.replace(<%- JSON.stringify(url_for('/search/?tag=' + encodeURIComponent(page.tag))) %>);
</script>

<%- partial('partial/footer') %>
