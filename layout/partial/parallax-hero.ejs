<!-- Parallax Hero Section -->
<section class="parallax-hero" id="parallaxHero" aria-label="<%= __('a11y.hero_banner') %>">
  <div class="parallax-layer parallax-layer--bg" id="parallaxBg" aria-hidden="true"></div>
  <div class="parallax-layer parallax-layer--foreground" id="parallaxForeground">
    <div class="hero-copy">
      <h1 class="hero-title kinetic-title">
        <span>JasonWoo's</span>
        <span>Blog</span>
      </h1>
      <p class="hero-subtitle"><%= theme.hero.subtitle %></p>
    </div>

    <div class="hero-posts-section">
      <h2 class="hero-posts-label" data-i18n="home.latest_posts"><%= __('home.latest_posts') %></h2>
      <div class="hero-posts" aria-label="<%= __('a11y.recent_posts') %>">
        <% (posts || []).forEach(function(post, i) { %>
          <a class="hero-post-card hero-post-card--text" href="<%= url_for(post.path) %>" aria-label="<%= post.title %>">
            <div class="hero-post-card__content">
              <div class="hero-post-card__headline">
                <span class="hero-post-card__index" aria-hidden="true"><%= String(i + 1).padStart(2, '0') %></span>
                <h3 class="hero-post-card__title"><%= post.title %></h3>
              </div>
              <div class="hero-post-card__meta">
                <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, theme.post.date_format) %></time>
                <% if (theme.post.reading_time && post.content) { %>
                  <% var wordCount = post.content.replace(/<[^>]+>/g, '').length; %>
                  <span>~<%= Math.max(1, Math.ceil(wordCount / 500)) %> <span data-i18n="post.min_read"><%= __('post.min_read') %></span></span>
                <% } %>
              </div>
            </div>
          </a>
        <% }) %>
      </div>
      <a class="hero-archive-link" href="<%= url_for('/archives/') %>" data-i18n="home.view_archives"><%= __('home.view_archives') %></a>
    </div>
  </div>
</section>
